// часть Б
class Microorganism {
private:
    char* name;
    double size;
    static double minSize;

public:
    Microorganism(const char* n, double s) : size(s) {
        name = new char[strlen(n) + 1];
        strcpy(name, n);
        if (s < minSize) minSize = s;
    }

    virtual ~Microorganism() {
        delete[] name;
    }

    virtual void show() const {
        cout << name << size << " mkm";
    }

    virtual const char* getType() const {
        return "Microorganism";
    }

    static double getMinSize() {
        return minSize;
    }
};

double Microorganism::minSize = 999999;

class Bacteria : public Microorganism {
private:
    char* shape;
public:
    Bacteria(const char* n, double s, const char* sh) : Microorganism(n, s) {
        shape = new char[strlen(sh) + 1];
        strcpy(shape, sh);
    }
    
    ~Bacteria() {
        delete[] shape;
    }
    
    void show() const override {
        cout << "[Bacteria] " << getType() << ", shape: " << shape;
    }
    
    const char* getType() const override {
        return "Bacteria";
    }
};

class Virus : public Microorganism {
private:
    bool hasRNA;
public:
    Virus(const char* n, double s, bool rna) : Microorganism(n, s), hasRNA(rna) {}
    
    void show() const override {
        cout << "[Virus] " << getType() << ", RNA: " << (hasRNA ? "yes" : "no");
    }
    
    const char* getType() const override {
        return "Virus";
    }
};

// часть А
class CharList {
private:
    struct Node {
        char data;
        Node* next;
        Node(char val) : data(val), next(nullptr) {}
    };
    
    Node* head;
    int count;
    
public:
    CharList() : head(nullptr), count(0) {}
    
    ~CharList() {
        while (head) {
            Node* temp = head;
            head = head->next;
            delete temp;
        }
    }
    
    void addToEnd(char val) {
        Node* newNode = new Node(val);
        if (!head) {
            head = newNode;
        } else {
            Node* curr = head;
            while (curr->next) curr = curr->next;
            curr->next = newNode;
        }
        count++;
    }
    
    void removeFromEnd() {
        if (!head) return;
        if (!head->next) {
            delete head;
            head = nullptr;
        } else {
            Node* curr = head;
            while (curr->next->next) curr = curr->next;
            delete curr->next;
            curr->next = nullptr;
        }
        count--;
    }
    
    CharList operator+(char item) const {
        CharList result = *this;
        result.addToEnd(item);
        return result;
    }
    
    CharList& operator--(int) {
        removeFromEnd();
        return *this;
    }
    
    bool operator!=(const CharList& other) const {
        if (count != other.count) return true;
        
        Node* a = head;
        Node* b = other.head;
        
        while (a && b) {
            if (a->data != b->data) return true;
            a = a->next;
            b = b->next;
        }
        return false;
    }
    
    void print() const {
        Node* curr = head;
        while (curr) {
            cout << curr->data << " ";
            curr = curr->next;
        }
        cout << endl;
    }
    
    int size() const { return count; }
};

